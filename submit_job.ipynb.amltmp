{
  "cells": [
    {
      "cell_type": "markdown",
      "source": [
        "#### Dependencies"
      ],
      "metadata": {
        "nteract": {
          "transient": {
            "deleting": false
          }
        }
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import os\n",
        "from azure.core.exceptions import HttpResponseError\n",
        "from azure.ai.ml import MLClient, command, Input, Output, dsl\n",
        "from azure.ai.ml.entities import AmlCompute, Environment, CommandJob, BuildContext, Data\n",
        "from azure.identity import DefaultAzureCredential, ManagedIdentityCredential\n",
        "from azureml.core import Workspace, Experiment, Datastore\n",
        "from azure.ai.ml.constants import AssetTypes"
      ],
      "outputs": [],
      "execution_count": 1,
      "metadata": {
        "gather": {
          "logged": 1774288889465
        }
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "#### Create Handle"
      ],
      "metadata": {
        "nteract": {
          "transient": {
            "deleting": false
          }
        }
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# obtain workspace auth details from local config file\n",
        "ws = Workspace.from_config()\n",
        "\n",
        "# choose credential access route\n",
        "credential = ManagedIdentityCredential()\n",
        "#credential = DefaultAzureCredential()\n",
        "\n",
        "ml_client = MLClient(\n",
        "    credential=credential,\n",
        "    subscription_id=ws.subscription_id,\n",
        "    resource_group_name=ws.resource_group,\n",
        "    workspace_name=ws.name\n",
        ")"
      ],
      "outputs": [
        {
          "output_type": "stream",
          "name": "stderr",
          "text": "Class DeploymentTemplateOperations: This is an experimental class, and may change at any time. Please see https://aka.ms/azuremlexperimental for more information.\n"
        }
      ],
      "execution_count": 2,
      "metadata": {
        "gather": {
          "logged": 1774288897315
        }
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "#### Create YAML file"
      ],
      "metadata": {
        "nteract": {
          "transient": {
            "deleting": false
          }
        }
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# create env folder if one doesn't exist\n",
        "dependencies_dir = \"./env\"\n",
        "os.makedirs(dependencies_dir, exist_ok=True)"
      ],
      "outputs": [],
      "execution_count": 3,
      "metadata": {
        "gather": {
          "logged": 1772645210906
        }
      }
    },
    {
      "cell_type": "code",
      "source": [
        "%%writefile {dependencies_dir}/environment.yml\n",
        "name: ray-env-chatgpt\n",
        "channels:\n",
        "  - conda-forge\n",
        "dependencies:\n",
        "  - python=3.10\n",
        "  - pip\n",
        "  - pip:\n",
        "    - torch\n",
        "    - torchvision\n",
        "    - ray[default]"
      ],
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": "Overwriting ./env/environment.yml\n"
        }
      ],
      "execution_count": 8,
      "metadata": {}
    },
    {
      "cell_type": "markdown",
      "source": [
        "#### Define Environment"
      ],
      "metadata": {
        "nteract": {
          "transient": {
            "deleting": false
          }
        }
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Define environment\n",
        "env = Environment(\n",
        "    name=\"ray-env-chatgpt\",\n",
        "    description=\"Ray training environment to experiment running ray on AzureML\",\n",
        "    tags={\"ray\": \"ray-torch\"},\n",
        "    conda_file=os.path.join(dependencies_dir, \"environment.yml\"),\n",
        "    image=\"mcr.microsoft.com/azureml/openmpi4.1.0-ubuntu20.04\"\n",
        ")\n",
        "\n",
        "ml_client.environments.create_or_update(env)\n",
        "\n",
        "print(\n",
        "    f\"Environment with name {env} is registered to workspace, the env version is {env.version}\")"
      ],
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": "Environment with name conda_file:\n  channels:\n  - conda-forge\n  dependencies:\n  - python=3.10\n  - pip\n  - pip:\n    - torch\n    - torchvision\n    - ray[default]\n  name: ray-env-chatgpt\ndescription: Ray training environment to experiment running ray on AzureML\nimage: mcr.microsoft.com/azureml/openmpi4.1.0-ubuntu20.04\nname: ray-env-chatgpt\ntags:\n  ray: ray-torch\nversion: '1'\n is registered to workspace, the env version is 1\n"
        }
      ],
      "execution_count": 9,
      "metadata": {
        "gather": {
          "logged": 1772645536049
        }
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "##### Define and Create Data Asset"
      ],
      "metadata": {
        "nteract": {
          "transient": {
            "deleting": false
          }
        }
      }
    },
    {
      "cell_type": "code",
      "source": [
        "data_path = \"./data/train.pt\"\n",
        "\n",
        "# Define the Data Asset Object\n",
        "my_data = Data(\n",
        "    path = data_path,\n",
        "    type=AssetTypes.URI_FILE,\n",
        "    description=\"This data set represents the fashionMNIST train set images\",\n",
        "    name=\"fashion_mnist_train_data\",\n",
        "    version=\"1\"\n",
        ")\n",
        "\n",
        "ml_client.data.create_or_update(my_data)"
      ],
      "outputs": [
        {
          "output_type": "stream",
          "name": "stderr",
          "text": "\u001b[32mUploading train.pt\u001b[32m (< 1 MB): 100%|██████████| 47.5M/47.5M [00:01<00:00, 39.2MB/s]\n\u001b[39m\n\n"
        },
        {
          "output_type": "execute_result",
          "execution_count": 5,
          "data": {
            "text/plain": "Data({'path': 'azureml://subscriptions/6edfe71f-db9c-4622-8259-95e374d29cf2/resourcegroups/kam-east/workspaces/kamunya-ml-first/datastores/workspaceblobstore/paths/LocalUpload/d8d07406efe68a541dcdae21d6e6079317282d9e4e02708a0fe8a020e7744f2e/train.pt', 'skip_validation': False, 'mltable_schema_url': None, 'referenced_uris': None, 'type': 'uri_file', 'is_anonymous': False, 'auto_increment_version': False, 'auto_delete_setting': None, 'name': 'fashion_mnist_train_data', 'description': 'This data set represents the fashionMNIST train set images', 'tags': {}, 'properties': {}, 'print_as_yaml': False, 'id': '/subscriptions/6edfe71f-db9c-4622-8259-95e374d29cf2/resourceGroups/kam-east/providers/Microsoft.MachineLearningServices/workspaces/kamunya-ml-first/data/fashion_mnist_train_data/versions/1', 'Resource__source_path': '', 'base_path': '/mnt/batch/tasks/shared/LS_root/mounts/clusters/kamumic3/code/Users/kamumic1/notebooks/fashion-ray-azure', 'creation_context': <azure.ai.ml.entities._system_data.SystemData object at 0x7686cf125ea0>, 'serialize': <msrest.serialization.Serializer object at 0x7686ceece590>, 'version': '1', 'latest_version': None, 'datastore': None})"
          },
          "metadata": {}
        }
      ],
      "execution_count": 5,
      "metadata": {
        "gather": {
          "logged": 1774285309078
        }
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "#### Define Job"
      ],
      "metadata": {
        "nteract": {
          "transient": {
            "deleting": false
          }
        }
      }
    },
    {
      "cell_type": "code",
      "source": [
        "compute_name = 'mlc-kamunya3'\n",
        "#compute_name = 'kamunya-vm-1'\n",
        "data_asset_path = \"azureml://subscriptions/6edfe71f-db9c-4622-8259-95e374d29cf2/resourcegroups/KAM-East/workspaces/kamunya-ml-first/datastores/workspaceblobstore/paths/LocalUpload/d8d07406efe68a541dcdae21d6e6079317282d9e4e02708a0fe8a020e7744f2e\"\n",
        "\n",
        "# Keep type=\"uri_folder\" in the Input definition\n",
        "\n",
        "# Define command job\n",
        "job = command(\n",
        "    code=\"./src\",\n",
        "    command=\"python train.py --data_dir ${{inputs.fashion_mnist}}\",\n",
        "    inputs={\n",
        "        \"fashion_mnist\": Input(\n",
        "            type=\"uri_folder\",\n",
        "            #path=\"./data\",\n",
        "            path=data_asset_path,\n",
        "            mode=\"mount\"\n",
        "        )\n",
        "    },\n",
        "\n",
        "    environment=\"ray-env-chatgpt@latest\",\n",
        "    compute=compute_name,\n",
        "    experiment_name=\"fashion-mnist-ray-chatgpt\",\n",
        "    shm_size = \"10g\"\n",
        ")\n",
        "\n",
        "returned_job = ml_client.jobs.create_or_update(job)\n",
        "print(returned_job.studio_url)"
      ],
      "outputs": [
        {
          "output_type": "stream",
          "name": "stderr",
          "text": "\u001b[32mUploading src (0.0 MBs): 100%|██████████| 4449/4449 [00:00<00:00, 108413.51it/s]\n\u001b[39m\n\n"
        },
        {
          "output_type": "stream",
          "name": "stdout",
          "text": "https://ml.azure.com/runs/elated_worm_qq64bptrrw?wsid=/subscriptions/6edfe71f-db9c-4622-8259-95e374d29cf2/resourcegroups/kam-east/workspaces/kamunya-ml-first&tid=89660ab5-e50f-4bea-983d-53e5468b6aba\n"
        }
      ],
